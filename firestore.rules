rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string
    //   - email: string
    //   - displayName: string
    //   - lastSeen: timestamp
    //   - online: bool
    //   - schools, classes, students, schedule, settings: app data
    //
    // Collection: chats
    // Document ID: {chatId}
    // Fields:
    //   - participants: list (uids)
    //   - participantNames: map (uid -> name)
    //   - isGroup: bool
    //   - name: string (optional for groups)
    //   - lastMessage: string
    //   - lastMessageAt: timestamp
    //   - createdAt: timestamp
    //
    // Subcollection: chats/{chatId}/messages
    // Fields:
    //   - senderId: string
    //   - senderName: string
    //   - text: string
    //   - timestamp: timestamp
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    match /users/{userId} {
      // Permite ler qualquer usuário para encontrar por e-mail ao iniciar chat
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
